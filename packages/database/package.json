{
  "name": "@cosmetic-lens/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma validate --schema prisma/schema.prisma",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:bootstrap": "tsx src/bootstrap.ts",
    "db:import:open-beauty-facts": "tsx src/cli/open-beauty-facts.ts",
    "db:enrich:pubchem": "tsx src/cli/pubchem.ts",
    "db:enrich:comptox": "tsx src/cli/comptox.ts",
    "db:validate:sources": "tsx src/cli/validate-sources.ts",
    "db:rebuild-search": "tsx src/cli/rebuild-search.ts",
    "data:validate": "tsx src/cli/seed-bundle.ts validate",
    "data:import": "tsx src/cli/seed-bundle.ts import",
    "data:import:sources": "tsx src/cli/seed-bundle.ts sources",
    "data:import:ingredients": "tsx src/cli/seed-bundle.ts ingredients",
    "data:import:evidence": "tsx src/cli/seed-bundle.ts evidence",
    "data:import:products": "tsx src/cli/seed-bundle.ts products",
    "data:report": "tsx src/cli/seed-bundle.ts report",
    "import:status": "tsx src/cli/import-status.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "@cosmetic-lens/importers": "workspace:*",
    "@cosmetic-lens/shared": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "pg": "8.16.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "prisma": "7.8.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
