# Application
APP_NAME="化妝品成分資料平台"
APP_ENGLISH_NAME="Cosmetic Ingredient Database"
APP_URL="http://localhost:3000"
NODE_ENV="development"

# PostgreSQL for Prisma
DATABASE_URL="postgresql://cosmetics:cosmetics@localhost:5432/cosmetics_lens?schema=public"

# Development admin credentials. Replace before production use.
ADMIN_EMAIL="admin@example.test"
ADMIN_PASSWORD="change-me-in-dev"
AUTH_COOKIE_SECRET="replace-with-at-least-32-random-characters"

# Local object storage / MinIO
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="cosmetic-labels"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true"

# Upload limits
UPLOAD_MAX_FILES="5"
UPLOAD_MAX_FILE_MB="8"
